{
  "name": "coderev",
  "displayName": "CodeRev",
  "description": "AI-powered code review using RAG",
  "publisher": "zen-karia",
  "repository": {
    "type": "git",
    "url": "https://github.com/zen-karia/CodeRev"
  },
  "icon": "images/icon.png",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "coderev.indexWorkspace",
        "title": "CodeRev: Index Workspace"
      },
      {
        "command": "coderev.reviewPR",
        "title": "CodeRev: Review PR"
      }
    ],
    "configuration": {
      "properties": {
          "coderev.githubToken": { "type": "string", "description": "GitHub personal access token" },
          "coderev.repoOwner": { "type": "string", "description": "GitHub repo owner" },
          "coderev.repoName": { "type": "string", "description": "GitHub repo name" }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.118.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
